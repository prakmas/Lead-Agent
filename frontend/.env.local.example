# The app calls its own API routes (same origin).
NEXT_PUBLIC_API_URL=/api

# ── Server-side only (no NEXT_PUBLIC_ prefix → never sent to the browser) ──
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Shown to customers when there's no match (optional). Leave blank to fall back
# to "reply 'call me'". Example: BUSINESS_CONTACT=+91 98765 43210
BUSINESS_NAME=
BUSINESS_CONTACT=

# MongoDB Atlas (database: crr)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/crr?retryWrites=true&w=majority
ATLAS_URI=mongodb+srv://<user>:<password>@<cluster-host>/crr?retryWrites=true&w=majority

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@crr.local
ADMIN_PASSWORD=Admin@12345

# Meta / WhatsApp (see META_KEYS_SETUP.md)
META_VERIFY_TOKEN=make-a-long-random-string
META_APP_SECRET=
META_API_VERSION=v20.0

WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
INSTAGRAM_PAGE_ID=
INSTAGRAM_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# AI provider: gemini | openai | claude | mock
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Twilio Verify (OTP) — get from Twilio console; leave blank to use dev codes
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
